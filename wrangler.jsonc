{
  "$schema": "./node_modules/wrangler/config-schema.json",
  // OpenNext creates this Worker entry file during its build.
  "main": ".open-next/worker.js",
  "name": "nick-chan-personal-site",
  "compatibility_date": "2026-07-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    // Hashed CSS, JavaScript, fonts, and the build-time page cache live here.
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
