# Public site settings. NEXT_PUBLIC values are included in browser JavaScript.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BOOKING_URL=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=

# Server-only inquiry delivery settings. Never prefix these with NEXT_PUBLIC.
TURNSTILE_SECRET_KEY=
RESEND_API_KEY=
INQUIRY_TO_EMAIL=
INQUIRY_FROM_EMAIL="Nick Chan <inquiries@your-domain.com>"

# Local-only form testing. The Server Action refuses preview mode in production.
INQUIRY_PREVIEW_MODE=false
